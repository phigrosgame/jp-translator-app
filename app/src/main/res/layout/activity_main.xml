<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="日語直播翻譯字幕"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="即時擷取系統音訊，日語翻中文"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="狀態：準備中，正在下載必要模型..."
        android:textSize="16sp"
        android:textColor="#FFD700"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:padding="12dp"
        android:background="#22ffffff" />

    <ProgressBar
        android:id="@+id/progressDownload"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="語音辨識模型"
        android:textSize="14sp"
        android:textColor="#aaaaaa"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/modelGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp">

        <RadioButton
            android:id="@+id/rbSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="快速（小，約 50MB，預設）"
            android:textColor="#dddddd"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="高精度（大，約 1GB，辨識更準）"
            android:textColor="#dddddd" />
    </RadioGroup>

    <TextView
        android:id="@+id/tvModelHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnFloatPerm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="開啟懸浮窗權限"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模型下載中，請稍候..."
        android:textSize="18sp"
        android:textStyle="bold"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="停止翻譯"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\n使用說明：\n1. 先開啟懸浮窗權限\n2. 點擊開始翻譯，授予錄製權限\n3. 打開直播APP即可看到懸浮字幕\n4. 字幕可以拖動調整位置\n5. 首次使用需要下載語音與翻譯模型（約 50~80MB），請保持網路連線\n\n進階：想免下載換用高精度大模型，可在 PC 解壓 vosk-model-ja-0.22 後，用 USB 放到手機的\nAndroid/data/com.jptranslator.app/files/models/\n資料夾裡，開 App 選「高精度」即會自動載入。更新 App 時模型也會保留、不用重下。"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginTop="32dp" />

</LinearLayout>